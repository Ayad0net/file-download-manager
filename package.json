{
  "name": "web-download-manager",
  "version": "1.0.0",
  "description": "Web-based file download manager",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch backend/src/index.ts",
    "start": "bun run backend/src/index.ts",
    "build": "tsc -p backend/tsconfig.json",
    "typecheck": "tsc --noEmit -p backend/tsconfig.json"
  },
  "dependencies": {
    "sql.js": "^1.11.0",
    "hono": "^4.7.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.8.0"
  },
  "trustedDependencies": ["sql.js"]
}
